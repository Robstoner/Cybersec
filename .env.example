# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.

# --- JWT ---
# Required. Use a long random string (min 32 chars).
JWT_SECRET=your-super-secret-jwt-key-change-me

# --- Database (dev profile) ---
# Defaults to the docker-compose values if not set.
DB_URL=jdbc:postgresql://localhost:5432/workouttracker
DB_USERNAME=postgres
DB_PASSWORD=postgres

# --- Bootstrap admin (optional) ---
# If all three are set, the backend seeds this user with ROLE_ADMIN on first startup.
# Skipped silently if any is blank, or if the username already exists.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-please
